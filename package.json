{
  "name": "citation-fidelity",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "description": "CLI-first tooling for auditing citation fidelity in scientific literature.",
  "exports": {
    "./config": "./src/config/index.ts",
    "./shared": "./src/shared/index.ts",
    "./storage": "./src/storage/index.ts",
    "./ui-contract": "./src/ui-contract/index.ts",
    "./ui-contract/server": "./src/ui-contract/server.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "cli": "tsx src/cli/index.ts",
    "dev": "tsx src/cli/index.ts",
    "doctor": "tsx src/cli/index.ts doctor",
    "db:migrate": "tsx src/cli/index.ts db:migrate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "ui:dev": "CITATION_FIDELITY_ROOT=$PWD npm --workspace @citation-fidelity/ui run dev",
    "ui:build": "CITATION_FIDELITY_ROOT=$PWD npm --workspace @citation-fidelity/ui run build",
    "ui:start": "CITATION_FIDELITY_ROOT=$PWD npm --workspace @citation-fidelity/ui run start"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubadahs/citation-fidelity.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bugs": {
    "url": "https://github.com/ubadahs/citation-fidelity/issues"
  },
  "homepage": "https://github.com/ubadahs/citation-fidelity#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@xmldom/xmldom": "^0.8.11",
    "ai": "^6.0.138",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/pdf-parse": "^1.1.5",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  }
}
