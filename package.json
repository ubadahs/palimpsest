{
  "name": "palimpsest",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "description": "CLI-first tooling for auditing citation fidelity in scientific literature.",
  "exports": {
    "./config": "./src/config/index.ts",
    "./shared": "./src/shared/index.ts",
    "./storage": "./src/storage/index.ts",
    "./contract": "./src/contract/index.ts",
    "./contract/server": "./src/contract/server.ts"
  },
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.build.json",
    "cli": "tsx src/cli/index.ts",
    "dev": "tsx src/cli/index.ts",
    "doctor": "tsx src/cli/index.ts doctor",
    "db:migrate": "tsx src/cli/index.ts db:migrate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:all": "npm run lint && npm --workspace @palimpsest/ui run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "ui:dev": "PALIMPSEST_ROOT=$PWD npm --workspace @palimpsest/ui run dev",
    "ui:build": "PALIMPSEST_ROOT=$PWD npm --workspace @palimpsest/ui run build",
    "ui:start": "PALIMPSEST_ROOT=$PWD npm --workspace @palimpsest/ui run start"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubadahs/palimpsest.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bugs": {
    "url": "https://github.com/ubadahs/palimpsest/issues"
  },
  "homepage": "https://github.com/ubadahs/palimpsest#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@xmldom/xmldom": "^0.8.12",
    "ai": "^6.0.146",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.2",
    "@types/pdf-parse": "^1.1.5",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
